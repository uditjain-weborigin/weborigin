# Sanity — public client config (safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID="z7lt73v0"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-02-01"

# Used by Visual Editing to link from the live site back to the Studio
NEXT_PUBLIC_SANITY_STUDIO_URL="http://localhost:3000/studio"

# Public site URL (used for sitemap, OG, JSON-LD, draft-mode redirects)
NEXT_PUBLIC_SITE_URL="https://theweborigin.com"

# Read-only token for the Live Content API & draft mode (DO NOT prefix with NEXT_PUBLIC_)
# Create one at: https://www.sanity.io/manage/project/z7lt73v0/api#tokens
# Permission: "Viewer" is enough.
SANITY_API_READ_TOKEN=""

# Shared secret for the /api/revalidate webhook (any random long string)
# Configure the same value in your Sanity GROQ-powered webhook.
SANITY_REVALIDATE_SECRET=""
